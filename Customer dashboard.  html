<!DOCTYPE html>
<html lang="hi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My Dashboard - Vibe Jewelry</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">
  <style>.gold { color: #d4af37; }</style>
</head>
<body class="bg-gray-50">

  <nav class="bg-white shadow sticky top-0 z-50">
    <div class="max-w-7xl mx-auto px-6 py-5 flex justify-between items-center">
      <h1 class="text-3xl font-bold gold">VIBE</h1>
      <a href="index.html" class="text-xl">Home</a>
    </div>
  </nav>

  <div class="max-w-4xl mx-auto p-6">
    <h1 class="text-4xl font-light gold text-center mb-12">Welcome Back!</h1>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <!-- My Orders -->
      <div onclick="window.location.href='myorders.html'" class="bg-white p-10 rounded-3xl shadow hover:shadow-xl cursor-pointer">
        <i class="fas fa-shopping-bag text-5xl gold mb-6"></i>
        <h2 class="text-2xl font-medium">My Orders</h2>
        <p class="text-gray-600">Track your previous orders</p>
      </div>

      <!-- Shop -->
      <div onclick="window.location.href='shop.html'" class="bg-white p-10 rounded-3xl shadow hover:shadow-xl cursor-pointer">
        <i class="fas fa-store text-5xl gold mb-6"></i>
        <h2 class="text-2xl font-medium">Shop Now</h2>
        <p class="text-gray-600">Browse latest collection</p>
      </div>

      <!-- Cart -->
      <div onclick="window.location.href='cart.html'" class="bg-white p-10 rounded-3xl shadow hover:shadow-xl cursor-pointer">
        <i class="fas fa-shopping-cart text-5xl gold mb-6"></i>
        <h2 class="text-2xl font-medium">My Cart</h2>
        <p class="text-gray-600">View added items</p>
      </div>

      <!-- Account -->
      <div class="bg-white p-10 rounded-3xl shadow hover:shadow-xl cursor-pointer">
        <i class="fas fa-user text-5xl gold mb-6"></i>
        <h2 class="text-2xl font-medium">My Account</h2>
        <p class="text-gray-600">Profile & Addresses</p>
      </div>
    </div>
  </div>

</body>
</html>
