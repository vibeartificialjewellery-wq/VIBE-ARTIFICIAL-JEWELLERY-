<!DOCTYPE html>
<html lang="hi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Order Success - Vibe</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">
  <style>.gold { color: #d4af37; }</style>
</head>
<body class="bg-gray-50 min-h-screen flex items-center justify-center p-6">

  <div class="text-center max-w-sm">
    <div class="text-8xl mb-6">🎉</div>
    <h1 class="text-4xl font-light gold mb-3">Order Placed!</h1>
    <p class="text-gray-600 mb-10">Thank you for shopping with Vibe Jewelry ❤️</p>

    <div class="bg-white rounded-3xl p-8 shadow mb-8">
      <p class="text-sm text-gray-500">Order ID</p>
      <p class="text-2xl font-bold gold">#VIBE${Math.floor(100000 + Math.random()*900000)}</p>
    </div>

    <button onclick="window.location.href='shop.html'" 
            class="w-full py-5 bg-gradient-to-r from-amber-500 to-yellow-600 text-white rounded-3xl text-xl">
      Continue Shopping
    </button>
  </div>

</body>
</html>
